# ================================
# NEN1090 Backend - .env (TESTFASE)
# Default wachtwoord testfase: Wesselink2012!
# ================================

# ==== DATABASE (LOCAL PostgreSQL) ====
# Zorg dat PostgreSQL draait en dat database 'nen1090' bestaat.
# User: postgres
# Password: Wesselink2012!
DATABASE_URL=postgresql+psycopg://postgres:Wesselink2012!@localhost:5432/nen1090

# ==== SECURITY ====
# Voor testfase mogen deze eenvoudig zijn. In productie vervangen.
JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=14
PASSWORD_HASH_ROUNDS=12

# ==== CORS ====
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://nen1090.pages.dev

# ==== APP ====
ENV=dev
